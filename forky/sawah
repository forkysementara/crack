local Junkie = loadstring(game:HttpGet("https://jnkie.com/sdk/library.lua"))()
Junkie.service = "ForkyCrack"
Junkie.identifier = "14086"
Junkie.provider = "Forky Premium"

local result = (function()
    getgenv().UI_CLOSED = false
    local Players = game:GetService("Players")
    local TweenService = game:GetService("TweenService")
    local Lighting = game:GetService("Lighting")
    local RunService = game:GetService("RunService")
    
    local Colors = {
        background = Color3.fromRGB(15, 15, 20),
        primary = Color3.fromRGB(0, 122, 255),
        secondary = Color3.fromRGB(175, 82, 222),
        success = Color3.fromRGB(52, 199, 89),
        error = Color3.fromRGB(255, 59, 48),
        white = Color3.fromRGB(255, 255, 255),
        textDim = Color3.fromRGB(150, 150, 165),
        border = Color3.fromRGB(50, 50, 65),
    }

    local function handleKick(reason)
        local lp = Players.LocalPlayer
        if lp then
            lp:Kick("\n[Forky Crack]\n" .. (reason or "Access Denied"))
        else
            game:Shutdown()
        end
    end

    local function loadUIFactory()
        return function(Colors, Players, TweenService, Lighting)
            return function(self)
                if self.gui then self.gui:Destroy() end
                
                self.gui = Instance.new("ScreenGui")
                self.gui.Name = "Forky Crack"
                self.gui.IgnoreGuiInset = true
                self.gui.DisplayOrder = 9999
                
                local blur = Instance.new("BlurEffect")
                blur.Size = 0
                blur.Name = "BluuHubBlur"
                blur.Parent = Lighting
                
                local mainContainer = Instance.new("CanvasGroup")
                mainContainer.AnchorPoint = Vector2.new(0.5, 0.5)
                mainContainer.Position = UDim2.new(0.5, 0, 0.5, 0)
                mainContainer.Size = UDim2.new(0, 360, 0, 200)
                mainContainer.BackgroundColor3 = Colors.background
                mainContainer.BackgroundTransparency = 0.15
                mainContainer.BorderSizePixel = 0
                mainContainer.GroupTransparency = 1
                mainContainer.Parent = self.gui
                
                local corner = Instance.new("UICorner")
                corner.CornerRadius = UDim.new(0, 28)
                corner.Parent = mainContainer
                
                local stroke = Instance.new("UIStroke")
                stroke.Color = Colors.border
                stroke.Thickness = 2.5
                stroke.Transparency = 0.4
                stroke.Parent = mainContainer
                
                -- Logo Centerpiece (No Background)
                local logo = Instance.new("ImageLabel")
                logo.AnchorPoint = Vector2.new(0.5, 0.5)
                logo.Position = UDim2.new(0.5, 0, 0, 60)
                logo.Size = UDim2.new(0, 80, 0, 80)
                logo.BackgroundTransparency = 1
                logo.Image = "rbxassetid://113844030610691"
                logo.Parent = mainContainer
                
                -- Orbital Rings (The "Cool" Loading Effect)
                local orbitalContainer = Instance.new("Frame")
                orbitalContainer.AnchorPoint = Vector2.new(0.5, 0.5)
                orbitalContainer.Position = UDim2.new(0.5, 0, 0, 60)
                orbitalContainer.Size = UDim2.new(0, 110, 0, 110)
                orbitalContainer.BackgroundTransparency = 1
                orbitalContainer.Parent = mainContainer
                
                local function createOrbit(size, speed, color)
                    local orbit = Instance.new("Frame")
                    orbit.AnchorPoint = Vector2.new(0.5, 0.5)
                    orbit.Position = UDim2.new(0.5, 0, 0.5, 0)
                    orbit.Size = UDim2.new(0, size, 0, size)
                    orbit.BackgroundTransparency = 1
                    orbit.Parent = orbitalContainer
                    
                    local oStroke = Instance.new("UIStroke")
                    oStroke.Color = color
                    oStroke.Thickness = 1.5
                    oStroke.Transparency = 0.6
                    oStroke.Parent = orbit
                    
                    local oCorner = Instance.new("UICorner")
                    oCorner.CornerRadius = UDim.new(1, 0)
                    oCorner.Parent = orbit
                    
                    local dot = Instance.new("Frame")
                    dot.Size = UDim2.new(0, 6, 0, 6)
                    dot.Position = UDim2.new(0.5, size/2, 0.5, 0)
                    dot.AnchorPoint = Vector2.new(0.5, 0.5)
                    dot.BackgroundColor3 = color
                    dot.BorderSizePixel = 0
                    dot.Parent = orbit
                    Instance.new("UICorner", dot).CornerRadius = UDim.new(1,0)
                    
                    task.spawn(function()
                        local angle = 0
                        while orbit and orbit.Parent do
                            angle = angle + speed
                            orbit.Rotation = angle
                            RunService.RenderStepped:Wait()
                        end
                    end)
                    return orbit
                end
                
                local ring1 = createOrbit(95, 2, Colors.primary)
                local ring2 = createOrbit(115, -1.5, Colors.secondary)
                
                -- Labels
                local title = Instance.new("TextLabel")
                title.Position = UDim2.new(0, 0, 0, 115)
                title.Size = UDim2.new(1, 0, 0, 30)
                title.BackgroundTransparency = 1
                title.Text = "Forky Crack"
                title.TextColor3 = Colors.white
                title.Font = Enum.Font.GothamBold
                title.TextSize = 22
                title.Parent = mainContainer
                
                local status = Instance.new("TextLabel")
                status.Name = "StatusLabel"
                status.Position = UDim2.new(0, 0, 0, 145)
                status.Size = UDim2.new(1, 0, 0, 20)
                status.BackgroundTransparency = 1
                status.Text = "Establishing Protocol"
                status.TextColor3 = Colors.textDim
                status.Font = Enum.Font.GothamMedium
                status.TextSize = 14
                status.Parent = mainContainer
                
                self.elements = {
                    main = mainContainer,
                    status = status,
                    blur = blur,
                    logo = logo,
                    rings = {ring1, ring2}
                }
                
                self.showSuccess = function(self, msg)
                    self.elements.status.Text = msg or "Access Authorized"
                    self.elements.status.TextColor3 = Colors.success
                    TweenService:Create(self.elements.logo, TweenInfo.new(0.6, Enum.EasingStyle.Back), {Size = UDim2.new(0, 90, 0, 90)}):Play()
                    task.wait(1.5)
                end
                
                self.updateStatus = function(self, msg, color)
                    self.elements.status.Text = msg
                    if color then self.elements.status.TextColor3 = color end
                end

                self.close = function(self)
                    TweenService:Create(self.elements.main, TweenInfo.new(0.6, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {GroupTransparency = 1, Size = UDim2.new(0, 320, 0, 180)}):Play()
                    TweenService:Create(self.elements.blur, TweenInfo.new(0.6), {Size = 0}):Play()
                    task.wait(0.6)
                    self.gui:Destroy()
                    getgenv().UI_CLOSED = true
                end

                -- Entrance
                self.gui.Parent = game:GetService("CoreGui")
                mainContainer.Size = UDim2.new(0, 320, 0, 180)
                TweenService:Create(mainContainer, TweenInfo.new(0.8, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {GroupTransparency = 0, Size = UDim2.new(0, 360, 0, 200)}):Play()
                TweenService:Create(blur, TweenInfo.new(1), {Size = 28}):Play()
            end
        end
    end

    local UI = {}
    UI.__index = UI
    function UI.new() return setmetatable({}, UI) end
    function UI:createUI() loadUIFactory()(Colors, Players, TweenService, Lighting)(self) end

    -- Execution
    local ui = UI.new()
    ui:createUI()
    
    local key = getgenv().SCRIPT_KEY
    
    if not key or key == "" then
        ui:updateStatus("Critical: SCRIPT_KEY Missing", Colors.error)
        task.wait(2)
        handleKick("No license key provided.")
        return nil
    end

    ui:updateStatus("Synchronizing Hardware...", Colors.textDim)
    task.wait(1.5)

    local result = Junkie.check_key(key)
    
    if result and result.valid then
        ui:showSuccess(result.message == "KEYLESS" and "Node Authorized" or "License key Verified")
        ui:close()
        return key
    else
        -- PRECISE ERROR MAPPING based on Junkie Documentation
        local raw = result and result.message or "CONNECTION_ERROR"
        local mappedReason = "Access Denied: Unknown Error"
        
        if raw == "INVALID_KEY" or raw:find("invalid") then
            mappedReason = "Authentication Failed: License Key Invalid"
        elseif raw == "KEY_EXPIRED" or raw:find("expire") then
            mappedReason = "Authentication Failed: License Key Expired"
        elseif raw == "HWID_MISMATCH" or raw:find("hwid") or raw:find("bind") then
            mappedReason = "Hardware Error: Key bound to another device"
        elseif raw == "KEY_NOT_FOUND" then
            mappedReason = "Database Error: Key does not exist"
        elseif raw == "MAX_HWID_REACHED" then
            mappedReason = "Hardware Error: Max device limit reached"
        elseif raw == "IP_MISMATCH" then
            mappedReason = "Network Error: IP Address Mismatch"
        else
            mappedReason = "Security Error: " .. raw
        end
        
        ui:updateStatus(mappedReason, Colors.error)
        task.wait(2.8)
        handleKick(mappedReason)
        return nil
    end
end)()

